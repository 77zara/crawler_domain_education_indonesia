# ===========================================================================
# AITF SR-02 Crawler — Environment Configuration
# Tim 2 Sekolah Rakyat (AITF 2026)
# ===========================================================================
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai.
# ===========================================================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Crawler Settings ---
MAX_CONCURRENCY=5
NOTIFY_EVERY=100
CACHE_MODE=enabled

# --- Browser ---
HEADLESS=true
PAGE_TIMEOUT=60000

# --- Search Engine Discovery ---
SEARCH_DELAY=3.0
MIN_RELEVANCE_SCORE=2

# --- Extraction quality gate (0..1) ---
MIN_EXTRACTION_QUALITY=0.80

# --- Fuzzy science relevance (RapidFuzz, optional) ---
FUZZY_SCIENCE_THRESHOLD=88
FUZZY_SCIENCE_MIN_HITS=1

# --- Hugging Face ---
HF_TOKEN=your_hf_token

# --- Multi-worker (optional, no Docker) ---
# Jika menjalankan beberapa proses, set INSTANCE_ID berbeda agar output/DB tidak tabrakan.
# INSTANCE_ID=worker-1
# DISCOVERY_SHARD_COUNT=4
# DISCOVERY_SHARD_INDEX=0

# --- Output ---
# OUTPUT_FILE=data/crawl_output.jsonl
# URLS_FILE=urls.txt
