# ===========================================================================
# AITF SR-02 Crawler — Environment Configuration
# Tim 2 Sekolah Rakyat (AITF 2026)
# ===========================================================================
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai.
# ===========================================================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Crawler Settings ---
MAX_CONCURRENCY=5
NOTIFY_EVERY=100
CACHE_MODE=enabled

# --- Browser ---
HEADLESS=true
PAGE_TIMEOUT=60000

# --- Search Engine Discovery ---
SEARCH_DELAY=3.0
MIN_RELEVANCE_SCORE=2

# --- Hugging Face ---
HF_TOKEN=your_hf_token

# --- Output ---
# OUTPUT_FILE=data/crawl_output.jsonl
# URLS_FILE=urls.txt
